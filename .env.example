# ─── Hotels Aggregator API (fastify server: npm run dev / npm start) ───────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Auth ──────────────────────────────────────────────────────────────────
# Vergul bilan ajratilgan API kalitlar. RateRadar backend shu kalitlardan birini
# `x-api-key` sarlavhasida yuboradi (backend .env: HOTEL_SCRAPER_API_KEY).
API_KEYS=dev-key-123
# true qilsangiz API kalit umuman tekshirilmaydi (faqat lokal dev uchun).
AUTH_DISABLED=false

# ─── Cache (Redis) — ixtiyoriy. Bo'sh bo'lsa kesh o'chiriladi. ──────────────
REDIS_URL=
CACHE_TTL_SECONDS=1800

# ─── Database (Postgres) — ixtiyoriy (so'rovlar logi uchun). Bo'sh — log yo'q. ─
DATABASE_URL=

# ─── Scraping ──────────────────────────────────────────────────────────────
# Booking blok qilsa, residential proksi: http://user:pass@host:port
# Proksi auth proxy-chain orqali ishlanadi (barqaror). DataImpulse'da davlatni
# username'da bering: ...__cr.us  (skreyp USD/us bilan ketadi — mos bo'lsin).
# MUHIM: production'da (Railway) shu o'zgaruvchini ham qo'shing, aks holda
# datacenter IP bilan ishlab Booking/Google bloklaydi.
PROXY_URL=
# true (default) — DataImpulse uchun sticky session: bitta skreyp = bitta IP =
# barqaror narx. false qilsangiz har so'rov boshqa IP (narx sakraydi).
PROXY_STICKY=true
# Sekin internetda yuklash vaqtini ko'paytiradi (1 = normal)
TIME_MULTIPLIER=1
# Bir vaqtda nechta og'ir (brauzer) ish ishlaydi
SCRAPE_CONCURRENCY=2
MAX_RESULTS_LIMIT=50
# Rasm/font/CSS/media bloklash (default true) — tezroq + residential proksi
# trafigi (puli) kamayadi. Narx DOM'da matn — ma'lumot buzilmaydi. O'chirish: false
BLOCK_RESOURCES=true

# ─── Rate limit ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute

# ─── Tier C tashqi API (ixtiyoriy) ─────────────────────────────────────────
SERPAPI_KEY=
